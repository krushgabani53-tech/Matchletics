# Database Configuration
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sports_squad

# SQLite (for development/testing - uncomment if needed)
# DATABASE_URL=sqlite:///./sports_squad.db

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
